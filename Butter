            <div>
              <p style={{ margin:"0 0 10px", fontSize:"11px", fontWeight:700,
                color:"#6b7a8d", letterSpacing:"0.06em" }}>
                المتطلبات الأكاديمية والمهنية
              </p>
              {prog.requirements.map((r, i) => (
                <div key={i} style={{ display:"flex", gap:"8px", marginBottom:"6px", alignItems:"flex-start" }}>
                  <span style={{ color: tm.color, fontSize:"8px", marginTop:"5px", flexShrink:0 }}>●</span>
                  <span style={{ fontSize:"13px", color:"#2d3a4a", lineHeight:1.55 }}>{r}</span>
                </div>
              ))}
            </div>
            <div>
              <p style={{ margin:"0 0 10px", fontSize:"11px", fontWeight:700,
                color:"#6b7a8d", letterSpacing:"0.06em" }}>
                المزايا التعاقدية والمخرجات
              </p>
              {prog.benefits.map((b, i) => (
                <div key={i} style={{ display:"flex", gap:"8px", marginBottom:"6px", alignItems:"flex-start" }}>
                  <span style={{ color:"#1a5c2e", fontSize:"8px", marginTop:"5px", flexShrink:0 }}>●</span>
                  <span style={{ fontSize:"13px", color:"#2d3a4a", lineHeight:1.55 }}>{b}</span>
                </div>
              ))}
            </div>
          </div>
          <div style={{ marginTop:"16px", paddingTop:"14px", borderTop:"1px solid #edf0f4",
            display:"flex", justifyContent:"space-between", alignItems:"center",
            flexWrap:"wrap", gap:"8px" }}>
            <span style={{ fontSize:"12px", color:"#6b7a8d" }}>
              تاريخ الاستحقاق النهائي:{" "}
              <strong style={{ color:"#0d1b2e" }}>{formatDate(prog.deadline)}</strong>
            </span>
            {hasRegisterLink && (
              <a href={prog.registerLink} target="_blank" rel="noopener noreferrer"
                style={{ padding:"7px 16px", background: tm.color, color:"#fff",
                  fontSize:"12px", fontWeight:700, textDecoration:"none",
                  border:`1px solid ${tm.color}`, display:"inline-block" }}>
                التسجيل المباشر
              </a>
            )}
          </div>
        </div>
      )}
    </div>
  );
}

function NotesSection({ isAdmin }) {
  const [open, setOpen]       = useState(false);
  const [text, setText]       = useState("");
  const [sent, setSent]       = useState(false);
  const [messages, setMessages] = useState(() => {
    try {
      const raw = sessionStorage.getItem(MSG_KEY);
      return raw ? JSON.parse(raw).map(m => ({ ...m, text: decryptMsg(m.enc) })) : [];
    } catch { return []; }
  });

  const handleSend = () => {
    if (!text.trim()) return;
    const msg = {
      enc: encryptMsg(text.trim()),
      time: new Date().toLocaleString("ar-SA")
    };
    const updated = [...messages, { ...msg, text: text.trim() }];
    setMessages(updated);
    sessionStorage.setItem(MSG_KEY, JSON.stringify(updated.map(m => ({ enc: m.enc, time: m.time }))));
    setText("");
    setSent(true);
    setTimeout(() => setSent(false), 3000);
  };

  return (
    <div style={{ maxWidth:"1200px", margin:"0 auto", padding:"0 24px 40px" }}>
      <div style={{ background:"#fff", border:"1px solid #d8e0ea" }}>
        <button
          onClick={() => setOpen(o => !o)}
          style={{ width:"100%", padding:"16px 20px", background:"none", border:"none",
            cursor:"pointer", display:"flex", justifyContent:"space-between", alignItems:"center",
            direction:"rtl", fontSize:"13px", fontWeight:700, color:"#0d1b2e",
            fontFamily:"'IBM Plex Sans Arabic', sans-serif" }}>
          <span>ملاحظات وتعليقات</span>
          <span style={{ fontSize:"18px", color:"#6b7a8d", lineHeight:1 }}>{open ? "▲" : "▼"}</span>
        </button>

        {open && (
          <div style={{ padding:"0 20px 20px", borderTop:"1px solid #edf0f4" }}>
            <p style={{ margin:"14px 0 10px", fontSize:"12px", color:"#6b7a8d" }}>
              يمكنك إرسال ملاحظة أو استفسار — تظهر الرسائل حصرياً في لوحة التحكم
            </p>
            <textarea
              value={text}
              onChange={e => setText(e.target.value)}
              rows={4}
              placeholder="اكتب ملاحظتك هنا..."
              style={{ width:"100%", padding:"10px 14px", border:"1px solid #c8d0dc",
                fontSize:"13px", color:"#0d1b2e", background:"#fafbfc", resize:"vertical",
                outline:"none", fontFamily:"'IBM Plex Sans Arabic', sans-serif", lineHeight:1.7 }}
            />
            <div style={{ display:"flex", justifyContent:"flex-end", marginTop:"10px" }}>
              <button
                onClick={handleSend}
                disabled={!text.trim()}
                style={{ padding:"9px 28px", background: text.trim() ? "#0d1b2e" : "#8a9bb0",
                  color:"#fff", border:"none", fontWeight:700, fontSize:"13px",
                  cursor: text.trim() ? "pointer" : "not-allowed",
                  fontFamily:"'IBM Plex Sans Arabic', sans-serif" }}>
                {sent ? "تم الإرسال ✓" : "إرسال"}
              </button>
            </div>

            {isAdmin && messages.length > 0 && (
              <div style={{ marginTop:"20px", borderTop:"1px dashed #e8ecf0", paddingTop:"16px" }}>
                <p style={{ margin:"0 0 12px", fontSize:"11px", fontWeight:700,
                  color:"#6b7a8d", letterSpacing:"0.06em" }}>
                  الرسائل الواردة ({messages.length})
                </p>
                {messages.map((m, i) => (
                  <div key={i} style={{ background:"#f8f9fb", border:"1px solid #e8ecf0",
                    padding:"12px 14px", marginBottom:"8px" }}>
                    <p style={{ margin:"0 0 6px", fontSize:"13px", color:"#0d1b2e",
                      lineHeight:1.6, whiteSpace:"pre-wrap" }}>
                      {m.text}
                    </p>
                    <span style={{ fontSize:"11px", color:"#aab4c0" }}>{m.time}</span>
                  </div>
                ))}
              </div>
            )}

            {!isAdmin && messages.length > 0 && (
              <p style={{ margin:"12px 0 0", fontSize:"11px", color:"#aab4c0", textAlign:"center" }}>
                تم استلام رسائلك بنجاح
              </p>
            )}
          </div>
        )}
      </div>
    </div>
  );
}

function LawSphereApp() {
  const [programs, setPrograms]         = useState(INITIAL_PROGRAMS);
  const [search, setSearch]             = useState("");
  const [statusFilter, setStatusFilter] = useState("الكل");
  const [typeFilter, setTypeFilter]     = useState("الكل");
  const [modal, setModal]               = useState(null);
  const [isAdmin, setIsAdmin]           = useState(false);
  const [showLogin, setShowLogin]       = useState(false);
  const nextId = useRef(100);

  const STATUS_OPTIONS = ["الكل", "مفتوح", "مغلق قريباً", "قادم", "مغلق"];
  const TYPE_OPTIONS   = ["الكل", "حكومي", "شركات", "مهني", "دولي"];

  const displayed = programs
    .filter(p => {
      const q = search.trim();
      const matchSearch = !q
        || p.name.includes(q)
        || p.org.includes(q)
        || (p.tags || []).some(t => t.includes(q));
      const matchStatus = statusFilter === "الكل" || p.status === statusFilter;
      const matchType   = typeFilter   === "الكل" || p.type   === typeFilter;
      return matchSearch && matchStatus && matchType;
    })
    .sort((a, b) => (daysLeft(a.deadline) ?? 9999) - (daysLeft(b.deadline) ?? 9999));

  const handleSave = form => {
    if (form.id) {
      setPrograms(ps => ps.map(p => p.id === form.id ? form : p));
    } else {
      setPrograms(ps => [...ps, { ...form, id: nextId.current++ }]);
    }
    setModal(null);
  };

  const handleDelete = id => {
    if (window.confirm("هل أنت متأكد من رغبتك في حذف هذا البرنامج نهائياً؟")) {
      setPrograms(ps => ps.filter(p => p.id !== id));
    }
  };

  const openCount = programs.filter(p => p.status === "مفتوح").length;
  const soonCount = programs.filter(p => {
    const d = daysLeft(p.deadline);
    return d !== null && d > 0 && d <= 14;
  }).length;

  return (
    <div style={{ minHeight:"100vh", background:"#f5f7fa", direction:"rtl" }}>

      <header style={{ background:"#0b1320", color:"#fff", borderBottom:"4px solid #16243d" }}>
        <div style={{ maxWidth:"1200px", margin:"0 auto", padding:"0 24px" }}>

          <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center",
            padding:"14px 0", borderBottom:"1px solid rgba(255,255,255,0.06)" }}>
            <span style={{ fontSize:"15px", fontWeight:700, color:"#fff", letterSpacing:"0.06em" }}>
              LawSphere
            </span>
            <button
              onClick={() => isAdmin ? setIsAdmin(false) : setShowLogin(true)}
              style={{ background:"transparent", border:"1px solid rgba(255,255,255,0.18)",
                color:"rgba(255,255,255,0.75)", padding:"6px 16px", fontSize:"12px",
                cursor:"pointer", letterSpacing:"0.04em" }}>
              {isAdmin ? "إغلاق لوحة التحكم" : "دخول المسؤول"}
            </button>
          </div>

          <div style={{ padding:"36px 0 28px", textAlign:"center" }}>
            {isAdmin && (
              <div style={{ marginBottom:"16px", padding:"8px 14px", display:"inline-block",
                background:"rgba(255,255,255,0.06)", border:"1px solid rgba(255,255,255,0.12)" }}>
                <span style={{ fontSize:"12px", color:"rgba(255,255,255,0.75)", fontWeight:600,
                  letterSpacing:"0.04em" }}>
                  وضع المسؤول الإضافة والتعديل والحذف مفعّلة
                </span>
              </div>
            )}
            <h1 style={{ margin:"0 0 6px", fontSize:"clamp(22px, 4vw, 32px)", fontWeight:900,
              letterSpacing:"0.02em" }}>
              برامج تطوير الخريجين
            </h1>
            <p style={{ margin:"0 0 28px", fontSize:"16px", color:"rgba(255,255,255,0.7)",
              fontWeight:500 }}>
              لتخصص القانون
            </p>

            <div style={{ display:"flex", gap:"1px", flexWrap:"wrap", justifyContent:"center" }}>
              {[
                [programs.length, "إجمالي البرامج"],
                [openCount,       "مفتوح للتقديم"],
                [soonCount,       "ينتهي خلال أسبوعين"]
              ].map(([n, lbl]) => (
                <div key={lbl} style={{ background:"rgba(255,255,255,0.05)",
                  border:"1px solid rgba(255,255,255,0.09)", padding:"12px 28px", minWidth:"130px" }}>
                  <p style={{ margin:0, fontSize:"22px", fontWeight:700, color:"#fff" }}>{n}</p>
                  <p style={{ margin:0, fontSize:"11px", color:"rgba(255,255,255,0.45)", marginTop:"3px" }}>{lbl}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </header>

      <main style={{ maxWidth:"1200px", margin:"0 auto", padding:"28px 24px" }}>

        <div style={{ background:"#fff", border:"1px solid #d8e0ea",
          padding:"16px 20px", marginBottom:"20px" }}>
          <p style={{ margin:"0 0 12px", fontSize:"12px", fontWeight:700, color:"#0d1b2e",
            letterSpacing:"0.04em" }}>
            دليل الإشارات الزمنية
          </p>
          <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:"8px 24px" }}>
            {[
              ["#2e5cb8", "متاح التقديم مفتوح والمدة كافية"],
              ["#1a5c2e", "ينتهي قريباً المدة المتبقية أسبوع"],
              ["#b7950b", "ينتهي قريباً المدة المتبقية ثلاثة أيام"],
              ["#922b21", "انتهت الفرصة"]
            ].map(([clr, lbl]) => (
              <div key={lbl} style={{ display:"flex", alignItems:"center", gap:"10px" }}>
                <span style={{ width:"12px", height:"12px", borderRadius:"50%",
                  background: clr, display:"inline-block", flexShrink:0 }} />
                <span style={{ fontSize:"12px", color:"#2d3a4a", fontWeight:500 }}>{lbl}</span>
              </div>
            ))}
          </div>
        </div>

        <div style={{ display:"flex", gap:"10px", marginBottom:"20px", flexWrap:"wrap" }}>
          <input
            value={search}
            onChange={e => setSearch(e.target.value)}
            placeholder="البحث باسم الجهة أو التخصص..."
            style={{ flex:"1 1 240px", padding:"11px 16px", border:"1px solid #c8d0dc",
              fontSize:"14px", color:"#0d1b2e", background:"#fff", outline:"none" }}
          />
          {isAdmin && (
            <button
              onClick={() => setModal("add")}
              style={{ padding:"11px 24px", background:"#0d1b2e", color:"#fff",
                border:"none", fontWeight:700, fontSize:"14px", cursor:"pointer",
                whiteSpace:"nowrap" }}>
              إدراج برنامج
            </button>
          )}
        </div>

        <div style={{ background:"#fff", border:"1px solid #d8e0ea",
          padding:"16px 20px", marginBottom:"24px" }}>
          <div style={{ display:"flex", flexWrap:"wrap", alignItems:"center",
            gap:"8px", marginBottom:"12px" }}>
            <span style={{ fontSize:"12px", color:"#6b7a8d", fontWeight:700,
              width:"96px", flexShrink:0 }}>
              حالة التقديم:
            </span>
            {STATUS_OPTIONS.map(opt => (
              <button key={opt} onClick={() => setStatusFilter(opt)}
                style={{ padding:"5px 14px", fontSize:"12px", cursor:"pointer",
                  border:"1px solid",
                  borderColor: statusFilter === opt ? "#0d1b2e" : "#c8d0dc",
                  background:  statusFilter === opt ? "#0d1b2e" : "#fff",
                  color:       statusFilter === opt ? "#fff"    : "#4a5568",
                  fontWeight:  statusFilter === opt ? 600       : 400 }}>
                {opt}
              </button>
            ))}
          </div>
          <div style={{ display:"flex", flexWrap:"wrap", alignItems:"center",
            gap:"8px", borderTop:"1px dashed #e8ecf0", paddingTop:"12px" }}>
            <span style={{ fontSize:"12px", color:"#6b7a8d", fontWeight:700,
              width:"96px", flexShrink:0 }}>
              نوع الجهة:
            </span>
            {TYPE_OPTIONS.map(opt => (
              <button key={opt} onClick={() => setTypeFilter(opt)}
                style={{ padding:"5px 14px", fontSize:"12px", cursor:"pointer",
                  border:"1px solid",
                  borderColor: typeFilter === opt ? "#0d1b2e" : "#c8d0dc",
                  background:  typeFilter === opt ? "#0d1b2e" : "#fff",
                  color:       typeFilter === opt ? "#fff"    : "#4a5568",
                  fontWeight:  typeFilter === opt ? 600       : 400 }}>
                {opt}
              </button>
            ))}
          </div>
        </div>

        <p style={{ margin:"0 0 16px", fontSize:"12px", color:"#6b7a8d",
          fontWeight:600, letterSpacing:"0.04em" }}>
          {displayed.length} برنامج مرتبة حسب قرب موعد الإغلاق
        </p>

        {displayed.length === 0 ? (
          <div style={{ padding:"60px 20px", textAlign:"center",
            background:"#fff", border:"1px solid #d8e0ea" }}>
            <p style={{ margin:0, fontSize:"14px", color:"#6b7a8d" }}>
              لا توجد برامج مطابقة لخيارات التصفية الحالية.
            </p>
          </div>
        ) : (
          <div style={{ display:"grid",
            gridTemplateColumns:"repeat(auto-fill, minmax(340px, 1fr))", gap:"16px" }}>
            {displayed.map(prog => (
              <ProgramCard
                key={prog.id}
                prog={prog}
                onEdit={p => setModal(p)}
                onDelete={handleDelete}
                isAdmin={isAdmin}
              />
            ))}
          </div>
        )}
      </main>

      <NotesSection isAdmin={isAdmin} />

      <footer style={{ borderTop:"1px solid #d8e0ea", background:"#fff", padding:"24px 24px" }}>
        <div style={{ maxWidth:"1200px", margin:"0 auto", textAlign:"center" }}>
          <p style={{ margin:"0 0 14px", fontSize:"13px", color:"#6b7a8d",
            fontStyle:"italic", lineHeight:1.8, maxWidth:"620px", marginInline:"auto" }}>
            "دليل برامج الخريجين سعيٌ فردي لاختصار عناء البحث، وفتح نوافذ التأهيل المهني أمام كفاءات القانون."
          </p>
          <div style={{ display:"flex", justifyContent:"space-between", flexWrap:"wrap",
            gap:"8px", alignItems:"center", paddingTop:"14px", borderTop:"1px solid #edf0f4" }}>
            <p style={{ margin:0, fontSize:"12px", color:"#6b7a8d", fontWeight:600 }}>
              LawSphere دليل برامج تطوير خريجي القانون
            </p>
            <p style={{ margin:0, fontSize:"11px", color:"#aab4c0" }}>
              البيانات للأغراض الإرشادية يُرجى التحقق من المصادر الرسمية قبل التقديم
            </p>
          </div>
        </div>
      </footer>

      {showLogin && (
        <LoginModal
          onSuccess={() => { setIsAdmin(true); setShowLogin(false); }}
          onClose={() => setShowLogin(false)}
        />
      )}
      {modal && isAdmin && (
        <ProgramModal
          program={modal === "add" ? null : modal}
          onSave={handleSave}
          onClose={() => setModal(null)}
        />
      )}
    </div>
  );
}

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(<LawSphereApp />);
</script>
</body>
</html>
