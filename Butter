const MSG_KEY = "Gradstep112_secure_msgs";

function encryptMsg(text) {
  return btoa(unescape(encodeURIComponent(text)));
}
function decryptMsg(encoded) {
  try { return decodeURIComponent(escape(atob(encoded))); } catch { return ""; }
}

const STATUS_META = {
  "مفتوح":       { color: "#ffffff", bg: "#1a5c2e", label: "مفتوح للتقديم",  dot: "#1a5c2e" },
  "مغلق قريباً": { color: "#ffffff", bg: "#7a4800", label: "ينتهي قريباً",   dot: "#b7950b" },
  "قادم":        { color: "#ffffff", bg: "#1a3a6b", label: "قادم",            dot: "#1a3a6b" },
  "مغلق":        { color: "#ffffff", bg: "#6b1a1a", label: "مغلق",            dot: "#922b21" }
};

const TYPE_META = {
  "حكومي": { color: "#1a3a6b" },
  "شركات": { color: "#1a5c2e" },
  "مهني":  { color: "#5a3a00" },
  "دولي":  { color: "#4c1a6b" }
};

function daysLeft(d) {
  if (!d) return null;
  return Math.ceil((new Date(d) - new Date()) / 86400000);
}

function formatDate(d) {
  if (!d) return "غير محدد";
  return new Date(d).toLocaleDateString("ar-SA", {
    year: "numeric", month: "long", day: "numeric"
  });
}

function getDeadlineDisplay(days, deadline) {
  if (days === null) return null;
  const dateStr = deadline ? `  (${formatDate(deadline)})` : "";
  if (days <= 0)  return { color: "#922b21", label: `انتهت الفرصة${dateStr}` };
  if (days <= 3)  return { color: "#b7950b", label: `ينتهي خلال 3 أيام${dateStr}` };
  if (days <= 7)  return { color: "#1a5c2e", label: `ينتهي خلال أسبوع${dateStr}` };
  return           { color: "#2e5cb8", label: `التقديم مفتوح · ${days} يوم متبقٍ${dateStr}` };
}

function LoginModal({ onSuccess, onClose }) {
  const [pw, setPw]           = useState("");
  const [error, setError]     = useState("");
  const [loading, setLoading] = useState(false);

  const handle = async () => {
    setLoading(true);
    setError("");
    await new Promise(r => setTimeout(r, 400));
    if (pw === "Gradstep112") {
      onSuccess();
    } else {
      setError("كلمة المرور غير صحيحة، يرجى مراجعة الصلاحيات.");
    }
    setLoading(false);
  };

  return (
    <div style={{ position:"fixed", inset:0, background:"rgba(10,20,40,0.6)", zIndex:2000,
      display:"flex", alignItems:"center", justifyContent:"center", padding:"16px" }}>
      <div style={{ background:"#fff", width:"100%", maxWidth:"380px", padding:"32px",
        direction:"rtl", boxShadow:"0 20px 25px -5px rgba(0,0,0,0.15)" }}>
        <p style={{ margin:"0 0 4px", fontSize:"11px", color:"#6b7a8d", fontWeight:600, letterSpacing:"0.08em" }}>
          بوابة الإدارة
        </p>
        <h2 style={{ margin:"0 0 24px", fontSize:"20px", fontWeight:700, color:"#0d1b2e" }}>
          تسجيل دخول المسؤول
        </h2>
        <label style={{ display:"block", fontSize:"12px", fontWeight:600, color:"#4a5568", marginBottom:"6px" }}>
          كلمة المرور
        </label>
        <input
          type="password"
          value={pw}
          onChange={e => setPw(e.target.value)}
          onKeyDown={e => e.key === "Enter" && handle()}
          autoFocus
          style={{ width:"100%", padding:"10px 12px", border:`1px solid ${error ? "#c0392b" : "#c8d0dc"}`,
            fontSize:"14px", color:"#0d1b2e", outline:"none", marginBottom:"8px", background:"#fafbfc" }}
        />
        {error && (
          <p style={{ margin:"0 0 12px", fontSize:"12px", color:"#c0392b", fontWeight:600 }}>
            {error}
          </p>
        )}
        <div style={{ display:"flex", gap:"8px", marginTop:"16px" }}>
          <button
            onClick={handle}
            disabled={loading || !pw}
            style={{ flex:1, padding:"10px", background: loading || !pw ? "#8a9bb0" : "#0d1b2e",
              color:"#fff", border:"none", fontWeight:700, fontSize:"14px",
              cursor: loading || !pw ? "not-allowed" : "pointer" }}>
            {loading ? "جارٍ التحقق..." : "تأكيد الدخول"}
          </button>
          <button
            onClick={onClose}
            style={{ padding:"10px 18px", background:"#fff", border:"1px solid #c8d0dc",
              cursor:"pointer", color:"#4a5568", fontSize:"14px" }}>
            إلغاء
          </button>
        </div>
      </div>
    </div>
  );
}

